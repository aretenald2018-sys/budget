{
  "name": "budget-app",
  "version": "0.1.0",
  "description": "1인용 가계부 — GitHub Pages 정적 UI와 Gmail 영수증 동기화",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "dev": "python -m http.server 5501",
    "dev:5502": "python -m http.server 5502",
    "apk:build": "node scripts/build-android-apk.mjs --out public/downloads/budget.apk",
    "pages:build": "node scripts/build-pages.mjs",
    "deploy:pages": "npm run apk:build && npm run verify && npm run pages:build && git push origin main",
    "verify": "node scripts/verify-project.mjs",
    "verify:android-notification": "node scripts/verify-android-notification-e2e.mjs",
    "verify:recipes": "node scripts/verify-recipe-autofill.mjs",
    "verify:registered-recipes": "node scripts/verify-registered-recipes.mjs",
    "verify:deployed-recipe-api": "node scripts/verify-deployed-recipe-api.mjs",
    "github:secrets": "node scripts/sync-github-secrets.mjs",
    "recipes:sync": "node scripts/github-recipe-sync.mjs",
    "telegram:sync": "node scripts/telegram-feed-sync.mjs",
    "telegram:static": "node scripts/telegram-feed-static.mjs",
    "gmail:auth": "node scripts/gmail-oauth-helper.mjs",
    "gmail:sync": "node scripts/github-sync-latest.mjs",
    "ideas:next": "node scripts/dev-idea-queue.mjs next",
    "ideas:list": "node scripts/dev-idea-queue.mjs list",
    "ideas:claim": "node scripts/dev-idea-queue.mjs claim-next",
    "ideas:complete": "node scripts/dev-idea-queue.mjs complete",
    "ideas:fail": "node scripts/dev-idea-queue.mjs fail",
    "ideas:reset": "node scripts/dev-idea-queue.mjs reset"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "sf-pro": "^1.0.4"
  }
}

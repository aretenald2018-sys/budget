<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reward_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/reward_widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/reward_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans"
            android:text="오늘의 적립"
            android:textColor="#f8fafc"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/reward_widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans"
            android:text="대기 중"
            android:textColor="#94a3b8"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/reward_widget_saved"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans"
        android:singleLine="true"
        android:text="앱을 열어 갱신"
        android:textColor="#ffffff"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/reward_widget_baseline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:fontFamily="sans"
        android:singleLine="true"
        android:text="홈 화면 계산 후 표시"
        android:textColor="#cbd5e1"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/reward_widget_wine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans"
            android:singleLine="true"
            android:text="와인 -"
            android:textColor="#fecdd3"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/reward_widget_ingredient"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans"
            android:gravity="center"
            android:singleLine="true"
            android:text="재료 -"
            android:textColor="#bbf7d0"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/reward_widget_travel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans"
            android:gravity="end"
            android:singleLine="true"
            android:text="여행 -"
            android:textColor="#bfdbfe"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reward_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/reward_widget_background"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="6dp"
    android:paddingEnd="12dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/reward_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans"
            android:text="오늘의 적립"
            android:textColor="#f8fafc"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/reward_widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans"
            android:text="대기 중"
            android:textColor="#94a3b8"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/reward_widget_saved"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="sans"
        android:singleLine="true"
        android:text="앱을 열어 갱신"
        android:textColor="#ffffff"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/reward_widget_baseline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:ellipsize="end"
        android:fontFamily="sans"
        android:singleLine="true"
        android:text="홈 화면 계산 후 표시"
        android:textColor="#cbd5e1"
        android:textSize="9sp" />

    <LinearLayout
        android:id="@+id/reward_widget_rows"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/reward_widget_wine_row"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:background="@drawable/reward_widget_row_background">

            <ProgressBar
                android:id="@+id/reward_widget_wine_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="100"
                android:maxHeight="24dp"
                android:minHeight="24dp"
                android:progress="0"
                android:progressDrawable="@drawable/reward_widget_progress" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/reward_widget_wine_mark"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/reward_widget_mark_background"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:text="와"
                    android:textColor="#6366f1"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reward_widget_wine"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="sans"
                    android:singleLine="true"
                    android:text="와인 -"
                    android:textColor="#f8fafc"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reward_widget_wine_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans"
                    android:singleLine="true"
                    android:text="-"
                    android:textAlignment="viewEnd"
                    android:textColor="#f8fafc"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/reward_widget_ingredient_row"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/reward_widget_row_background">

            <ProgressBar
                android:id="@+id/reward_widget_ingredient_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="100"
                android:maxHeight="24dp"
                android:minHeight="24dp"
                android:progress="0"
                android:progressDrawable="@drawable/reward_widget_progress" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/reward_widget_ingredient_mark"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/reward_widget_mark_background"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:text="재"
                    android:textColor="#6366f1"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reward_widget_ingredient"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="sans"
                    android:singleLine="true"
                    android:text="재료 -"
                    android:textColor="#f8fafc"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reward_widget_ingredient_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans"
                    android:singleLine="true"
                    android:text="-"
                    android:textAlignment="viewEnd"
                    android:textColor="#f8fafc"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/reward_widget_travel_row"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/reward_widget_row_background">

            <ProgressBar
                android:id="@+id/reward_widget_travel_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="100"
                android:maxHeight="24dp"
                android:minHeight="24dp"
                android:progress="0"
                android:progressDrawable="@drawable/reward_widget_progress" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/reward_widget_travel_mark"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/reward_widget_mark_background"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:text="여"
                    android:textColor="#6366f1"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reward_widget_travel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="sans"
                    android:singleLine="true"
                    android:text="여행 -"
                    android:textColor="#f8fafc"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reward_widget_travel_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans"
                    android:singleLine="true"
                    android:text="-"
                    android:textAlignment="viewEnd"
                    android:textColor="#f8fafc"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
